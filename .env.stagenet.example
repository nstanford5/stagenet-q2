# Copy to .env.stagenet and fill in the funded seeds. For each role set ONLY ONE
# of _MNEMONIC or _SEED. Roles that only submit transactions ("deployer",
# "relayer") MUST be funded with NIGHT on stagenet AND registered for DUST
# (the harness registers DUST automatically once NIGHT is present).
#
# Address-only roles ("trader", "lp", "caller_a", ...) never submit a tx — the
# deployer pays and submits on their behalf; they exist only to provide a
# distinct on-chain address. Any 64-char hex works and no funding is required.
#
# stagenet has no public faucet automation — fund the deployer/relayer NIGHT
# addresses out-of-band (operators / https://faucet.stagenet.shielded.tools/).

# ── funded submitters ──────────────────────────────────────────────────────
MIDNIGHT_STAGENET_DEPLOYER_SEED=replace-with-a-funded-64-char-hex-seed
MIDNIGHT_STAGENET_RELAYER_SEED=replace-with-a-funded-64-char-hex-seed

# ── address-only participants (no funding needed) ───────────────────────────
MIDNIGHT_STAGENET_TRADER_SEED=replace-with-any-64-char-hex-seed
MIDNIGHT_STAGENET_LP_SEED=replace-with-any-64-char-hex-seed

# ── caller dapp (compile-gap today; funded submitters when kernel.caller ships)
MIDNIGHT_STAGENET_CALLER_A_SEED=replace-with-any-64-char-hex-seed
MIDNIGHT_STAGENET_CALLER_B_SEED=replace-with-any-64-char-hex-seed
MIDNIGHT_STAGENET_SHIELDED_CALLER_SEED=replace-with-any-64-char-hex-seed
